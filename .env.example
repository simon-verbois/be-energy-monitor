# ── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_SERVER=192.168.0.50
SMTP_AUTH=none
SMTP_PORT=25
#SMTP_USER=your-email@gmail.com
#SMTP_PASSWORD=your-app-password
SMTP_FROM="Energy Monitor <noreply@example.org>"

# ── Recipients ────────────────────────────────────────────────────────────────
ALERT_EMAIL_TO="recipient@example.org"

# ── Alert Thresholds ──────────────────────────────────────────────────────────
OIL_ALERT_ENABLED=true
OIL_ALERT_THRESHOLD_PERCENT=5

FUEL_ALERT_ENABLED=false
FUEL_ALERT_THRESHOLD_PERCENT=3

ELEC_ALERT_ENABLED=true
ELEC_PRICE_CEILING=0.10

GAS_ALERT_ENABLED=false
GAS_ALERT_THRESHOLD_PERCENT=5

# ── Reports & Charts ──────────────────────────────────────────────────────────
ENABLE_DAILY_REPORT=true
ENABLE_WEEKLY_REPORT=true
CHART_MONTHS=3

# ── Language ──────────────────────────────────────────────────────────────────
# Supported: fr (French), en (English), nl (Dutch)
LANGUAGE=fr

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=Europe/Brussels

# ── TotalEnergies PDF URLs ────────────────────────────────────────────────────
TOTALENERGIES_ELEC_PDF_URL=https://totalenergies.be/static/marketing-documents/b2c/tariff-card/latest/MYESSENTIAL_ELECTRICITY_WAL_FR.pdf
TOTALENERGIES_GAS_PDF_URL=https://totalenergies.be/static/marketing-documents/b2c/tariff-card/latest/MYESSENTIAL_GAS_WAL_FR.pdf

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
