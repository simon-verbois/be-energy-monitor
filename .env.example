# ── SMTP Configuration ─────────────────────────────────────────────────────────
SMTP_SERVER=192.168.0.50

# Authentication mode:
#   starttls  — EHLO → STARTTLS → login (Gmail, Office 365, etc.)
#   none      — plain relay, no authentication (internal mail relay)
SMTP_AUTH=none

# Port: 25 for unauthenticated relays, 587 for STARTTLS (submission)
SMTP_PORT=25

# Required only when SMTP_AUTH=starttls
#SMTP_USER=your-email@gmail.com
#SMTP_PASSWORD=your-app-password

# Dedicated From address (required for relay mode, optional for STARTTLS — defaults to SMTP_USER)
SMTP_FROM="Energy Monitor <noreply@example.org>"

# ── Alert Recipients ────────────────────────────────────────────────────────────
ALERT_EMAIL_TO="recipient@example.org"

# ── Alert Thresholds ────────────────────────────────────────────────────────────

# Gasoil de chauffage (mazout)
# Alert when current price is X% LOWER than the 7-day average
OIL_ALERT_ENABLED=true
OIL_ALERT_THRESHOLD_PERCENT=5

# Carburants (Essence 95/98, Diesel B7)
# Alert when the monthly average max price drops X% vs the previous month
FUEL_ALERT_ENABLED=false
FUEL_ALERT_THRESHOLD_PERCENT=3

# Électricité day-ahead (Elia)
# Alert when hourly price drops BELOW this ceiling (€/kWh)
# Examples: 0.05 = 5 c€/kWh  |  0.10 = 10 c€/kWh  |  0.15 = 15 c€/kWh
# Typical Belgian range: 0.03–0.25 €/kWh
ELEC_ALERT_ENABLED=true
ELEC_PRICE_CEILING=0.10

# Gaz naturel (CREG tarif social trimestriel)
# Alert when a new quarter is cheaper than the previous one by X%
GAS_ALERT_ENABLED=false
GAS_ALERT_THRESHOLD_PERCENT=5

# ── Chart Window ────────────────────────────────────────────────────────────────
# Number of months of history shown in trend charts (oil, fuel, electricity)
# Gas chart always shows all available quarters regardless of this setting
CHART_MONTHS=3

# ── Scheduled Reports ───────────────────────────────────────────────────────────
ENABLE_DAILY_REPORT=true
ENABLE_WEEKLY_REPORT=true

# ── Timezone ────────────────────────────────────────────────────────────────────
# Do not change for Belgian context
TZ=Europe/Brussels

# ── TotalEnergies PDF URLs ───────────────────────────────────────────────────────
# Override if TotalEnergies changes the document path
TOTALENERGIES_ELEC_PDF_URL=https://totalenergies.be/static/marketing-documents/b2c/tariff-card/latest/MYESSENTIAL_ELECTRICITY_WAL_FR.pdf
TOTALENERGIES_GAS_PDF_URL=https://totalenergies.be/static/marketing-documents/b2c/tariff-card/latest/MYESSENTIAL_GAS_WAL_FR.pdf

# ── Logging ──────────────────────────────────────────────────────────────────────
# INFO  (default) — job events, prices stored, emails sent
# DEBUG           — adds parsed PDF values, regex matches, chart details, APScheduler internals
LOG_LEVEL=INFO
